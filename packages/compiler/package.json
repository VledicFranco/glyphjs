{
  "name": "@glyphjs/compiler",
  "version": "0.10.0",
  "description": "Compiles Glyph AST into IR with schema validation and diagnostics",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@glyphjs/ir": "workspace:*",
    "@glyphjs/parser": "workspace:*",
    "@glyphjs/schemas": "workspace:*",
    "@glyphjs/types": "workspace:*",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.7.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "Vledic Franco",
  "repository": {
    "type": "git",
    "url": "https://github.com/VledicFranco/glyphjs.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/VledicFranco/glyphjs#readme",
  "bugs": "https://github.com/VledicFranco/glyphjs/issues",
  "keywords": [
    "glyph",
    "glyphjs",
    "markdown",
    "react",
    "ui-components",
    "interactive-documents",
    "compiler",
    "ast",
    "ir"
  ]
}
